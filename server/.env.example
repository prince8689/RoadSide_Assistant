# ============================================
# ROADSIDE ASSIST — ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# App
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://username:password@localhost:5432/roadside_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roadside_db
DB_USER=postgres
DB_PASSWORD=

# JWT
JWT_SECRET=generate_a_random_64_char_string_here
JWT_EXPIRES_IN=7d

# Email (Brevo SMTP)
SMTP_USER=your_brevo_login_email
SMTP_PASS=your_brevo_smtp_master_password
SMTP_FROM="Roadside Assistant <noreply@yourdomain.com>"
TEST_EMAIL=your_personal_email_to_test

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google Maps (will use in Day 6)
GOOGLE_MAPS_API_KEY=will_add_later

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:5173
