# ============================================
# ROADSIDE ASSIST — ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# --- Server ---
NODE_ENV=development
PORT=5000

# --- PostgreSQL Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=roadside_assist
DB_USER=postgres
DB_PASSWORD=

# --- Redis Cache ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- JWT Authentication ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# --- CORS ---
CORS_ORIGIN=http://localhost:3000
